AIMAOS_DEFAULT_INPUT_DIR=data/raw
AIMAOS_DEFAULT_OUTPUT_DIR=data/reports
AIMAOS_LOG_DIR=data/logs
AIMAOS_ORGANIZATION_NAME=AI마케팅협회

# AIMAOS 데이터 수집 POC
# 실제 값은 이 파일에 넣지 말고 .env에만 입력하세요.
NAVER_SEARCHAD_CUSTOMER_ID=
NAVER_SEARCHAD_ACCESS_LICENSE=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_ACCOUNT_ALIAS=
AIMAOS_POC_ADVERTISER=
AIMAOS_POC_START_DATE=
AIMAOS_POC_END_DATE=
# 일시적 네트워크 오류 또는 429/5xx 응답 재시도 설정
AIMAOS_NAVER_API_MAX_ATTEMPTS=3
AIMAOS_NAVER_API_RETRY_DELAY_SECONDS=0.75
AIMAOS_POC_GMARKET_REPORT_URL=
AIMAOS_POC_AUCTION_REPORT_URL=
AIMAOS_POC_11ST_REPORT_URL=
